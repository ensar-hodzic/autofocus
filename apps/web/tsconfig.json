{
  "extends": "../../packages/config-typescript/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@convex/*": [
        "../../convex/*"
      ],
      "@autofocus/domain": [
        "../../packages/domain/src/index.ts"
      ],
      "@autofocus/domain/*": [
        "../../packages/domain/src/*"
      ]
    },
    "types": [
      "vite/client"
    ],
    "noEmit": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "vite.config.mjs"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
